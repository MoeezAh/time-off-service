{
  "name": "time-off-service",
  "version": "1.0.0",
  "description": "Production-grade Time-Off Microservice for ExampleHR",
  "main": "src/main.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev": "cross-env NODE_ENV=development node --env-file=.env src/main.js",
    "build": "node scripts/check-js.js",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint src tests scripts",
    "format": "prettier --write \"src/**/*.{js,jsx,json,md}\" \"tests/**/*.{js,jsx}\"",
    "db:migrate": "node src/infrastructure/database/migrate.js",
    "db:seed": "node src/infrastructure/database/seed.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:concurrency": "vitest run tests/concurrency --reporter=verbose",
    "docker:build": "docker build -t time-off-service:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}

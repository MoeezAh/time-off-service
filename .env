# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=sqlite://./data/time-off.db
DATABASE_LOGGING=false

# JWT (Mock Authentication)
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# HCM Integration
HCM_BASE_URL=http://localhost:3001
HCM_API_KEY=mock-api-key
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
HCM_RETRY_DELAY_MS=1000

# Event Processing
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=10

# Reconciliation
RECONCILIATION_CHECK_INTERVAL_MS=3600000

# CORS
CORS_ORIGIN=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
